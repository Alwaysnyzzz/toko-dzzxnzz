// functions/api/_helper.js — Helper JWT & password untuk Cloudflare Workers
// Pakai Web Crypto API (built-in) — tidak perlu npm

import { SignJWT, jwtVerify } from 'jose';
import { createClient } from '@supabase/supabase-js';

export const HEADERS = {
  'Content-Type': 'application/json',
  'Access-Control-Allow-Origin': '*',
  'Access-Control-Allow-Headers': 'Content-Type, Authorization',
};

export const CORS = new Response(null, {
  status: 204,
  headers: {
    'Access-Control-Allow-Origin': '*',
    'Access-Control-Allow-Methods': 'GET, POST, OPTIONS',
    'Access-Control-Allow-Headers': 'Content-Type, Authorization',
  }
});

// ===== JWT =====
function getJwtKey(secret) {
  return new TextEncoder().encode(secret);
}

export async function signJWT(payload, secret) {
  return new SignJWT(payload)
    .setProtectedHeader({ alg: 'HS256' })
    .setExpirationTime('7d')
    .sign(getJwtKey(secret));
}

export async function verifyJWT(token, secret) {
  const { payload } = await jwtVerify(token, getJwtKey(secret));
  return payload;
}

export function getToken(request) {
  const auth = request.headers.get('Authorization') || '';
  return auth.startsWith('Bearer ') ? auth.split(' ')[1] : null;
}

// ===== PASSWORD (PBKDF2 via Web Crypto) =====
// Simpan sebagai: iterations:salt:hash (semua base64)
const ITERATIONS = 100000;

export async function hashPassword(password) {
  const salt = crypto.getRandomValues(new Uint8Array(16));
  const keyMaterial = await crypto.subtle.importKey(
    'raw', new TextEncoder().encode(password),
    'PBKDF2', false, ['deriveBits']
  );
  const hashBuf = await crypto.subtle.deriveBits(
    { name: 'PBKDF2', salt, iterations: ITERATIONS, hash: 'SHA-256' },
    keyMaterial, 256
  );
  const saltB64 = btoa(String.fromCharCode(...salt));
  const hashB64 = btoa(String.fromCharCode(...new Uint8Array(hashBuf)));
  return `${ITERATIONS}:${saltB64}:${hashB64}`;
}

export async function verifyPassword(password, stored) {
  // Support format lama dari bcryptjs
  if (stored.startsWith('$2')) {
    // bcrypt hash — tidak bisa diverifikasi di Cloudflare Workers
    // Fallback: cek via Supabase Edge Function atau return false
    // Untuk sementara return false, user perlu reset password
    return false;
  }
  try {
    const [iter, saltB64, hashB64] = stored.split(':');
    const salt = Uint8Array.from(atob(saltB64), c => c.charCodeAt(0));
    const keyMaterial = await crypto.subtle.importKey(
      'raw', new TextEncoder().encode(password),
      'PBKDF2', false, ['deriveBits']
    );
    const hashBuf = await crypto.subtle.deriveBits(
      { name: 'PBKDF2', salt, iterations: Number(iter), hash: 'SHA-256' },
      keyMaterial, 256
    );
    const computed = btoa(String.fromCharCode(...new Uint8Array(hashBuf)));
    return computed === hashB64;
  } catch { return false; }
}

export function supabase(env) {
  return createClient(env.SUPABASE_URL, env.SUPABASE_SERVICE_KEY);
}

export function json(data, status = 200) {
  return new Response(JSON.stringify(data), { status, headers: HEADERS });
}
